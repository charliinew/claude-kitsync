#!/usr/bin/env bash
# bin/claude-kitsync — main CLI dispatcher for claude-kitsync
set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve the root of the kitsync installation
# Works whether called directly, via symlink, or sourced.
# ---------------------------------------------------------------------------
# Respect KITSYNC_ROOT if pre-set (e.g. by install.sh via symlink).
# Otherwise resolve from the real script location, following symlinks portably.
if [[ -z "${KITSYNC_ROOT:-}" ]] || [[ ! -d "${KITSYNC_ROOT}/lib" ]]; then
  _ks_script="${BASH_SOURCE[0]}"
  # Follow symlinks one level at a time (portable: macOS + Linux)
  while [[ -L "$_ks_script" ]]; do
    _ks_link="$(readlink "$_ks_script")"
    # Handle relative symlink targets
    [[ "$_ks_link" = /* ]] || _ks_link="$(cd "$(dirname "$_ks_script")" && pwd)/$_ks_link"
    _ks_script="$_ks_link"
  done
  KITSYNC_ROOT="$(cd "$(dirname "$_ks_script")/.." && pwd)"
  unset _ks_script _ks_link
fi
export KITSYNC_ROOT

# ---------------------------------------------------------------------------
# Load all libraries
# Order matters: core first (defines CLAUDE_HOME, logging), then the rest.
# ---------------------------------------------------------------------------
source "$KITSYNC_ROOT/lib/core.sh"
source "$KITSYNC_ROOT/lib/paths.sh"
source "$KITSYNC_ROOT/lib/sync.sh"
source "$KITSYNC_ROOT/lib/wrapper.sh"
source "$KITSYNC_ROOT/lib/init.sh"
source "$KITSYNC_ROOT/lib/install-kit.sh"
source "$KITSYNC_ROOT/lib/publish.sh"
source "$KITSYNC_ROOT/lib/settings.sh"
source "$KITSYNC_ROOT/lib/profiles.sh"
source "$KITSYNC_ROOT/lib/crypto.sh"

# ---------------------------------------------------------------------------
# version
# ---------------------------------------------------------------------------
KITSYNC_VERSION="$(<"${KITSYNC_ROOT}/VERSION" 2>/dev/null || echo "dev")"

# ---------------------------------------------------------------------------
# _usage — print help text
# ---------------------------------------------------------------------------
_usage() {
  cat >&2 <<USAGE

  ${_CLR_BOLD}${_CLR_CYAN}◆ claude-kitsync${_CLR_RESET}  v${KITSYNC_VERSION}
  ${_CLR_BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${_CLR_RESET}
  Sync your Claude config across machines via git.

  ${_CLR_BOLD}Usage${_CLR_RESET}
    claude-kitsync <command> [options]

  ${_CLR_BOLD}Commands${_CLR_RESET}
    ${_CLR_CYAN}init${_CLR_RESET} [--remote <url>]   Set up ~/.claude as a git repo + shell wrapper
    ${_CLR_CYAN}push${_CLR_RESET} [-m "msg"] [--dry-run]  Commit and push config changes to remote
    ${_CLR_CYAN}pull${_CLR_RESET} [--force]               Pull latest config from remote
    ${_CLR_CYAN}status${_CLR_RESET}                       Show modified files and ahead/behind count
    ${_CLR_CYAN}log${_CLR_RESET} [-n <count>]             Show sync history (default: last 15 commits)
    ${_CLR_CYAN}diff${_CLR_RESET}                         Show diff between local and remote
    ${_CLR_CYAN}publish${_CLR_RESET}                      Package and publish a kit to GitHub
    ${_CLR_CYAN}install${_CLR_RESET} <url>           Merge a public kit into ~/.claude
    ${_CLR_CYAN}profile${_CLR_RESET} [list|add|switch|remove]  Manage sync profiles (work, perso...)
    ${_CLR_CYAN}encrypt${_CLR_RESET} [enable|disable|rotate|status]  Encrypt settings.json before push
    ${_CLR_CYAN}settings${_CLR_RESET}                Change sync preferences (pull/push mode)
    ${_CLR_CYAN}upgrade${_CLR_RESET}                 Update claude-kitsync to the latest version
    ${_CLR_CYAN}doctor${_CLR_RESET}                  Run health checks on your setup
    ${_CLR_CYAN}restore${_CLR_RESET}                 Restore a rc file from a kitsync backup
    ${_CLR_CYAN}uninstall${_CLR_RESET}               Remove claude-kitsync completely

  ${_CLR_BOLD}Options${_CLR_RESET}
    -h, --help                Show this help
    -v, --version             Show version

  ${_CLR_BOLD}Examples${_CLR_RESET}
    claude-kitsync init
    claude-kitsync push -m "add new agent"
    claude-kitsync install https://github.com/someone/claude-kit

  ${_CLR_BOLD}Environment${_CLR_RESET}
    CLAUDE_HOME               Override default ~/.claude  (default: ~/.claude)
    KITSYNC_TIMEOUT           Background pull timeout in seconds  (default: 2)

USAGE
}

# ---------------------------------------------------------------------------
# cmd_doctor — diagnose health of the claude-kitsync setup
# ---------------------------------------------------------------------------
cmd_doctor() {
  local errors=0
  local warnings=0

  printf "\n"
  log_info "Running claude-kitsync doctor...\n"

  # Check 1: CLAUDE_HOME exists
  if [[ -d "$CLAUDE_HOME" ]]; then
    log_success "[1/6] CLAUDE_HOME exists: $CLAUDE_HOME"
  else
    log_error "[1/6] CLAUDE_HOME missing: $CLAUDE_HOME — run: claude-kitsync init"
    errors=$((errors + 1))
  fi

  # Check 2: Is a git repo
  if git -C "$CLAUDE_HOME" rev-parse --git-dir &>/dev/null 2>&1; then
    log_success "[2/6] $CLAUDE_HOME is a git repository"
  else
    log_error "[2/6] Not a git repo — run: claude-kitsync init"
    errors=$((errors + 1))
  fi

  # Check 3: Remote configured
  if git -C "$CLAUDE_HOME" remote get-url origin &>/dev/null 2>&1; then
    local remote_url
    remote_url="$(git -C "$CLAUDE_HOME" remote get-url origin 2>/dev/null)"
    log_success "[3/6] Remote configured: $remote_url"
  else
    log_warn "[3/6] No remote configured — run: git -C \"$CLAUDE_HOME\" remote add origin <url>"
    warnings=$((warnings + 1))
  fi

  # Check 4: Profile consistency
  local _active_profile
  _active_profile="$(_profile_get_active 2>/dev/null || true)"
  if [[ -n "$_active_profile" ]]; then
    local _profile_url _origin_url
    _profile_url="$(_profile_get_url "$_active_profile" 2>/dev/null || true)"
    _origin_url="$(git -C "$CLAUDE_HOME" remote get-url origin 2>/dev/null || true)"
    if [[ -n "$_profile_url" ]] && [[ "$_profile_url" == "$_origin_url" ]]; then
      log_success "[4/6] Profile '$_active_profile' matches origin remote"
    elif [[ -n "$_profile_url" ]] && [[ "$_profile_url" != "$_origin_url" ]]; then
      log_warn "[4/6] Profile '$_active_profile' URL mismatch — config: $_profile_url  origin: $_origin_url"
      log_warn "      Fix with: claude-kitsync profile switch $_active_profile"
      warnings=$((warnings + 1))
    else
      log_warn "[4/6] Active profile '$_active_profile' not found in config"
      warnings=$((warnings + 1))
    fi
  else
    log_success "[4/6] No profiles configured (single-remote mode)"
  fi

  # Check 5: Encryption key present if encryption is enabled
  if _crypto_is_enabled 2>/dev/null; then
    local _key_file; _key_file="$(_crypto_key_path)"
    if [[ -f "$_key_file" ]]; then
      log_success "[5/7] Encryption enabled — key file present"
    else
      log_error "[5/7] Encryption enabled but key file MISSING: $_key_file"
      log_error "      Copy your key here or run: claude-kitsync encrypt enable (to generate a new one)"
      errors=$((errors + 1))
    fi
  else
    log_success "[5/7] Encryption: disabled (opt-in)"
  fi

  # Check 6: .credentials.json is NOT tracked by git
  if git -C "$CLAUDE_HOME" ls-files --error-unmatch ".credentials.json" &>/dev/null 2>&1; then
    log_error "[6/7] CRITICAL: .credentials.json is tracked by git! Remove it immediately:"
    log_error "      git -C \"$CLAUDE_HOME\" rm --cached .credentials.json"
    errors=$((errors + 1))
  else
    log_success "[6/7] .credentials.json is NOT tracked (safe)"
  fi

  # Check 7: Shell wrapper installed
  local wrapper_found=false
  local zshrc="${ZDOTDIR:-$HOME}/.zshrc"
  local bashrc="$HOME/.bashrc"

  if { [[ -f "$zshrc" ]] && grep -qF "# kitsync-start" "$zshrc" 2>/dev/null; } || \
     { [[ -f "$bashrc" ]] && grep -qF "# kitsync-start" "$bashrc" 2>/dev/null; }; then
    wrapper_found=true
  fi

  if [[ "$wrapper_found" == "true" ]]; then
    log_success "[7/7] Shell wrapper found in rc file(s)"
  else
    log_warn "[7/7] Shell wrapper not found — run: claude-kitsync init"
    warnings=$((warnings + 1))
  fi

  printf "\n"

  if [[ $errors -gt 0 ]]; then
    log_error "Doctor found $errors error(s) and $warnings warning(s) — action required."
    return 1
  elif [[ $warnings -gt 0 ]]; then
    log_warn "Doctor found $warnings warning(s) — review recommended."
    return 0
  else
    log_success "All checks passed — claude-kitsync is healthy."
    return 0
  fi
}

# ---------------------------------------------------------------------------
# cmd_uninstall — full removal of claude-kitsync
#   1. Remove shell wrapper (claude() function) from rc files
#   2. Remove PATH injection from rc files
#   3. Remove binary symlink
#   4. Remove installation directory
# ---------------------------------------------------------------------------
cmd_uninstall() {
  printf "\n"
  log_info "Uninstalling claude-kitsync...\n"

  # Step 1: Remove shell wrapper block from rc files
  remove_wrapper

  # Step 2: Remove PATH entry from rc files
  _remove_path_from_rc "${ZDOTDIR:-$HOME}/.zshrc"
  _remove_path_from_rc "$HOME/.bashrc"

  # Step 3: Remove binary symlink (find it via PATH lookup)
  local bin_symlink
  bin_symlink="$(command -v claude-kitsync 2>/dev/null || true)"
  if [[ -n "$bin_symlink" ]] && [[ -L "$bin_symlink" ]]; then
    rm "$bin_symlink"
    log_success "Removed binary: $bin_symlink"
  elif [[ -L "$HOME/.local/bin/claude-kitsync" ]]; then
    rm "$HOME/.local/bin/claude-kitsync"
    log_success "Removed binary: $HOME/.local/bin/claude-kitsync"
  fi

  # Step 4: Remove installation directory
  # KITSYNC_ROOT is already set to the install dir (libs are loaded, safe to delete)
  if [[ -d "$KITSYNC_ROOT" ]]; then
    rm -rf "$KITSYNC_ROOT"
    log_success "Removed installation: $KITSYNC_ROOT"
  fi

  printf "\n"
  log_success "claude-kitsync fully uninstalled."
  log_info "Run 'exec \$SHELL' or open a new terminal to complete the removal."
  printf "\n"
}

# ---------------------------------------------------------------------------
# cmd_upgrade — pull latest version of claude-kitsync from GitHub
# ---------------------------------------------------------------------------
cmd_upgrade() {
  log_step "Checking for updates..."

  if [[ ! -d "$KITSYNC_ROOT/.git" ]]; then
    log_warn "KITSYNC_ROOT is not a git repo — can't auto-upgrade."
    log_warn "Re-run the installer to upgrade:"
    log_warn "  curl -fsSL https://raw.githubusercontent.com/charliinew/claude-kitsync/main/install.sh | bash"
    return 1
  fi

  local before_sha after_sha
  before_sha="$(git -C "$KITSYNC_ROOT" rev-parse --short HEAD 2>/dev/null || echo '?')"

  if git -C "$KITSYNC_ROOT" pull --rebase -q 2>&1; then
    after_sha="$(git -C "$KITSYNC_ROOT" rev-parse --short HEAD 2>/dev/null || echo '?')"
    if [[ "$before_sha" == "$after_sha" ]]; then
      log_success "Already up to date  ($after_sha)"
    else
      log_success "Upgraded: $before_sha → $after_sha"
    fi
  else
    log_warn "Upgrade failed — check your network and try again."
    return 1
  fi
}

# ---------------------------------------------------------------------------
# _post_pull_hook — internal hook called by shell wrapper after background pull
# Normalises paths in settings.json.
# ---------------------------------------------------------------------------
_post_pull_hook() {
  normalize_paths 2>/dev/null || true
  paths_detokenize 2>/dev/null || true
}

# ---------------------------------------------------------------------------
# Main dispatcher
# ---------------------------------------------------------------------------
main() {
  local cmd="${1:-}"

  case "$cmd" in
    init)
      shift
      cmd_init "$@"
      ;;
    push)
      shift
      local msg="" _push_auto="" _push_dry_run=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          -m)              shift; msg="${1:-}"; shift ;;
          --auto)          _push_auto="--auto"; shift ;;
          -n|--dry-run)    _push_dry_run="--dry-run"; shift ;;
          *)               msg="$1"; shift ;;
        esac
      done
      sync_push "${msg:-}" ${_push_auto} ${_push_dry_run}
      ;;
    pull)
      shift
      local force="${1:-}"
      sync_pull "$force"
      ;;
    status)
      sync_status
      ;;
    log)
      shift
      sync_log "${1:-15}"
      ;;
    diff)
      sync_diff
      ;;
    publish)
      cmd_publish
      ;;
    install)
      shift
      cmd_install "$@"
      ;;
    profile)
      shift
      cmd_profile "$@"
      ;;
    encrypt)
      shift
      cmd_encrypt "$@"
      ;;
    settings)
      cmd_settings
      ;;
    doctor)
      cmd_doctor
      ;;
    restore)
      cmd_restore
      ;;
    upgrade)
      cmd_upgrade
      ;;
    uninstall)
      cmd_uninstall
      ;;
    _post-pull-hook)
      _post_pull_hook
      ;;
    _install-wrapper)
      # Internal: called by install.sh on re-install to ensure wrapper is active
      install_wrapper_auto
      ;;
    -h|--help|help|"")
      _usage
      ;;
    -v|--version|version)
      echo "claude-kitsync $KITSYNC_VERSION"
      ;;
    *)
      log_error "Unknown command: $cmd"
      _usage
      exit 1
      ;;
  esac
}

main "$@"
